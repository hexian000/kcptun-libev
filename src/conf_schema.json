{
    "$schema": "https://json-schema.org/draft-07/schema",
    "type": "object",
    "properties": {
        "connect": { "type": "string" },
        "http_listen": { "type": "string" },
        "kcp_bind": { "type": "string" },
        "kcp_connect": { "type": "string" },
        "keepalive": { "type": "integer", "minimum": 0, "maximum": 600 },
        "kcp": {
            "type": "object",
            "properties": {
                "flush":    { "type": "integer", "minimum": 0,   "maximum": 2     },
                "interval": { "type": "integer", "minimum": 10,  "maximum": 500   },
                "mtu":      { "type": "integer", "minimum": 300, "maximum": 1500  },
                "nc":       { "type": "integer", "minimum": 0,   "maximum": 1     },
                "nodelay":  { "type": "integer", "minimum": 0,   "maximum": 2     },
                "rcvwnd":   { "type": "integer", "minimum": 16,  "maximum": 65536 },
                "resend":   { "type": "integer", "minimum": 0,   "maximum": 100   },
                "sndwnd":   { "type": "integer", "minimum": 16,  "maximum": 65536 }
            }
        },
        "linger": { "type": "integer", "minimum": 5, "maximum": 600 },
        "listen": { "type": "string" },
        "loglevel": { "type": "integer", "minimum": 0, "maximum": 8 },
        "method": { "type": "string" },
        "netdev": { "type": "string" },
        "obfs": { "type": "string" },
        "password": { "type": "string" },
        "psk": { "type": "string" },
        "rendezvous_server": { "type": "string" },
        "service_id": { "type": "string" },
        "tcp": {
            "type": "object",
            "properties": {
                "keepalive":  { "type": "boolean" },
                "nodelay":    { "type": "boolean" },
                "rcvbuf":     { "type": "integer", "minimum": 0, "maximum": 33554432 },
                "reuseport":  { "type": "boolean" },
                "sndbuf":     { "type": "integer", "minimum": 0, "maximum": 33554432 }
            }
        },
        "time_wait": { "type": "integer", "minimum": 5,  "maximum": 3600  },
        "timeout":   { "type": "integer", "minimum": 60, "maximum": 86400 },
        "udp": {
            "type": "object",
            "properties": {
                "rcvbuf":    { "type": "integer", "minimum": 0, "maximum": 33554432 },
                "reuseport": { "type": "boolean" },
                "sndbuf":    { "type": "integer", "minimum": 0, "maximum": 33554432 }
            }
        },
        "user": { "type": "string" }
    }
}
